{
  "version": 1,
  "serviceName": "ZeroLagRuntimeGuard",
  "displayName": "ZeroLag Runtime Guard",
  "description": "Visible Windows Service guard that restores ZeroLag runtime-only performance state after crashes, forced exits, expiry, or uninstall.",
  "serviceBinary": "ZeroLag.RuntimeGuard.Service.exe",
  "desktopWorkerBinary": "ZeroLag.exe",
  "serviceBinaryStatus": "native-wrapper-source",
  "nativeServiceWrapperStatus": "source-ready",
  "nativeServiceWrapperSource": "build/native-service",
  "nativeServiceWrapperBuildScript": "scripts/build-native-service-wrapper.js",
  "nativeServiceWrapperOutput": "build/native-service/dist/ZeroLag.RuntimeGuard.Service.exe",
  "installerRegistrationStatus": "explicit-private-validation-only",
  "serviceWorker": "service-guard/runtime-guard-service.js",
  "serviceCore": "service-guard/runtime-guard-core.js",
  "startupType": "Automatic",
  "account": "NT AUTHORITY\\LocalService",
  "visibleInWindowsServices": true,
  "sessionFile": "%LOCALAPPDATA%\\ZeroLag\\runtime-session.json",
  "watchdogScript": "scripts/runtime-watchdog.js",
  "installScript": "build/install-runtime-guard-service.ps1",
  "uninstallScript": "build/uninstall-runtime-guard-service.ps1",
  "uninstallCoordinator": "build/uninstall-runtime-cleanup.ps1",
  "taskSchedulerFallback": {
    "taskName": "ZeroLagRuntimeGuardFallback",
    "enabledWhenServiceInstallFails": true,
    "highestPrivileges": true,
    "intervalMinutes": 5,
    "triggers": [
      "user logon",
      "periodic cleanup"
    ],
    "registrationStatus": "explicit-private-validation-only",
    "installScript": "build/install-runtime-guard-task.ps1",
    "uninstallScript": "build/uninstall-runtime-guard-task.ps1"
  },
  "allowedActions": [
    "verify signed runtime session",
    "detect missing desktop heartbeat",
    "restore original power plan",
    "delete ZeroLag runtime power plans",
    "remove stale runtime session file",
    "run one cleanup pass during uninstall"
  ],
  "cleanupTriggers": [
    "desktop exit",
    "desktop force kill",
    "desktop crash",
    "user logoff",
    "windows restart",
    "subscription expiry",
    "integrity failure",
    "server authorization failure",
    "uninstall"
  ],
  "prohibitedBehaviors": [
    "hide service from Windows service tools",
    "block Task Manager",
    "kill user processes",
    "delete user files",
    "disable antivirus",
    "disable firewall",
    "disable Windows Security"
  ]
}
